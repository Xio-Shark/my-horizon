{
  "version": "1.0",
  "ai": {
    "provider": "openai",
    "model": "deepseek-v4-flash",
    "api_key_env": "DEEPSEEK_API_KEY",
    "base_url": "https://api.deepseek.com/v1",
    "temperature": 0.3,
    "max_tokens": 4096,
    "throttle_sec": 0,
    "languages": ["en", "zh"]
  },
  "sources": {
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 15,
      "min_score": 80
    },
    "rss": [
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true,
        "category": "ai-tools"
      },
      {
        "name": "Go Blog",
        "url": "https://go.dev/blog/feed.atom",
        "enabled": true,
        "category": "go"
      }
    ],
    "reddit": {
      "enabled": false,
      "fetch_comments": 5,
      "subreddits": [],
      "users": []
    },
    "github": [
      {
        "type": "repo_releases",
        "owner": "golang",
        "repo": "go",
        "enabled": true
      }
    ],
    "telegram": {
      "enabled": false
    }
  },
  "filtering": {
    "ai_score_threshold": 7.0,
    "time_window_hours": 24
  },
  "email": {
    "enabled": false,
    "smtp_server": "smtp.qq.com",
    "smtp_port": 465,
    "imap_server": "imap.qq.com",
    "imap_port": 993,
    "email_address": "your-email@qq.com",
    "password_env": "EMAIL_PASSWORD",
    "sender_name": "Horizon Daily",
    "subscribe_keyword": "SUBSCRIBE",
    "unsubscribe_keyword": "UNSUBSCRIBE"
  },
  "webhook": {
    "enabled": false
  }
}
